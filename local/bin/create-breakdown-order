#!/usr/bin/env python3

import pandas as pd
import subprocess
from datetime import datetime
from pathlib import Path

root = Path("/data/data/com.termux/files/home/storage/shared/equipment_manuals/_logs")

machines = pd.read_csv(root/"machines.csv")
sn = input("Enter machine SN: ").strip().upper()
product_code = sn[:3]

try:
    info = machines.set_index("Product Code").loc[product_code].to_dict()
except KeyError as k:
    print(f"Product Code {k} not found\n")
    model = input("Enter model: ").strip()
    instrument_type = input("Enter instrument type: ").strip()
    with open(root/"machines.csv", 'a') as f:
        f.write(f"{product_code},{model},{instrument_type}\n")
    info = {
            'Model': model,
            'Instrument Type': instrument_type
            }

expected_serial_num_length = 11 if product_code[-1] == "-" else 12

if len(sn) != expected_serial_num_length:
    print(f"Unexpected SN length: {len(sn)}.")

print("Select a customer:")
customer_file_path = root/"customers.txt"
with open(customer_file_path, "r") as f:
    lines = f.read()
customer = subprocess.run( ["fzf"], input=lines, text=True, capture_output=True)
customer = customer.stdout.strip()
if not customer:
    print("Customer not selected.")
    customer = input("Enter new customer name: ").strip()
    with open(customer_file_path, "a") as f:
        f.write(f"{customer}\n")
print(customer)

isUnderWarranty = input("Is the machine under warranty? [y/N] ")

if isUnderWarranty in 'yesYES':
    warranty_status = "(under warranty)"
else:
    warranty_status = "(not under warranty)"

description = input("Requests needing our support:\n")

def getSpareParts(count):
    spare_parts=pd.read_csv(root/"spareparts_partnumber.csv")
    isSparePartListAvailable = info['Model'] in spare_parts.iloc[:, 2].unique().tolist()

    if isSparePartListAvailable:
        df = spare_parts[spare_parts.iloc[:, 2] == info['Model']].reset_index(drop=True)
        print(f"Spare parts of {info['Model']}:\n", df.iloc[:, :2], "\n")
        selection = list(input(f"Select {count} spare parts:\n"))
        selection = [ int(item) for item in selection if item != " " ]
        if 0 < len(selection) <= count:
            try:
                df = df.iloc[selection, :2]
                df.index = [f"{i}." for i in range(1, len(df) + 1)]
                table = df.to_string(index=True, header=False)
                indented = "\n".join("    " + line for line in table.splitlines())
                necessary_spare_parts = f"\nSpare parts required {warranty_status}:\n{indented}"
                return necessary_spare_parts
            except IndexError:
                print("Index error")
        return None
    else:
        return None

isSparePartsRequired = input("Do you need to add any spare parts ? [y/N] ")

try:
    isSparePartsRequired = int(isSparePartsRequired)
except ValueError:
    if isSparePartsRequired in 'YESyes':
        isSparePartsRequired = 1
    else:
        necessary_spare_parts = None
finally:
    if isinstance(isSparePartsRequired, int):
        necessary_spare_parts = getSpareParts(count=isSparePartsRequired)

if necessary_spare_parts:
    description = description + "\n" + necessary_spare_parts

breakdown_order = f"""Product: {info['Instrument Type']}
Model: {info['Model']}
Serial Number: {sn}
Machine Located Country: Nepal
Hospital/Institution name: {customer}
Requests needing our support:
{description}
Distributor ID: S200560
Contact Person: Nikin (Service engineer @ GMS)
Contact: +977 9700047278
"""

subprocess.run(["termux-share", "-a", "send"], text=True, input=breakdown_order)

with open(root/"work-orders.md", "a") as f:
    f.write(f"""---
Order ID:
Work order created on {datetime.now().strftime('%Y-%m-%d')}:

{breakdown_order}
""")
