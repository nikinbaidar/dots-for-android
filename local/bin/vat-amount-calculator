#!/usr/bin/env python

def get_taxable_amount(total_amount, vat=0.13):
    taxable_amount = round(total_amount / (1 + vat), 4)
    vat_amount = round(vat * taxable_amount, 4)
    return taxable_amount, vat_amount


def get_total_amount(taxable_amount, vat=0.13):
    vat_amount = round(vat * taxable_amount, 4)
    total_amount = round(taxable_amount + vat_amount, 4)
    return total_amount, vat_amount


def read_float(prompt):
    while True:
        try:
            return float(input(prompt))
        except ValueError:
            print("Enter a valid number.")


ans = input("Press 't' for taxable from total, 'T' for total from taxable (default T): ").strip()

if ans == 't':
    total = read_float("Enter total amount (VAT inclusive): ")
    taxable, vat = get_taxable_amount(total)
else:
    taxable = read_float("Enter taxable amount (VAT exclusive): ")
    total, vat = get_total_amount(taxable)

print("\n--- Result ---")
print(f"Taxable amount = {taxable:.2f}")
print(f"VAT amount     = {vat:.2f}")
print(f"Total amount   = {total:.2f}")
print("\n")
